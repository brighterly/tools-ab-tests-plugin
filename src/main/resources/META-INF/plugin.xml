<idea-plugin require-restart="false">
    <id>com.brighterly.experiments</id>
    <name>AB Tests</name>
    <vendor>Brighterly</vendor>
    <description><![CDATA[
        <p>
            First-class IDE support for A/B experiment keys defined in PHP or JSON config files.
            Works across PHP, JavaScript, TypeScript, and Vue files.
        </p>

        <h3>Config file support</h3>
        <ul>
            <li>Supports both <b>PHP</b> (<code>experiments.php</code>) and <b>JSON</b> (<code>experiments.json</code>) config formats.</li>
            <li>Multiple config files — configure any number of paths in <b>Settings → Tools → AB Tests</b>.</li>
            <li>Auto-detects <code>config/experiments.php</code> and <code>config/experiments.json</code> in open projects when no paths are configured.</li>
            <li>Config index reloads automatically when a config file is saved.</li>
        </ul>

        <h3>Inlay hints</h3>
        <ul>
            <li>Shows <code>[50/50]</code> distribution after each open experiment key.</li>
            <li>Shows <code>[override_branch]</code> after each closed (overridden) experiment key.</li>
            <li>Works in PHP, JS, TS, and Vue <code>&lt;script&gt;</code> blocks.</li>
        </ul>

        <h3>Editor annotations</h3>
        <ul>
            <li><b>Strikethrough</b> — closed experiments are rendered with a strikethrough to signal they are no longer active.</li>
            <li><b>Branch sum warning</b> — highlights experiment keys in config files when branch percentages do not sum to 100%.</li>
        </ul>

        <h3>Navigation &amp; references</h3>
        <ul>
            <li><b>Ctrl+Click</b> on any experiment key jumps to its definition in the config file.</li>
            <li><b>Cmd+Click</b> on a key inside the config file shows all usages across the project.</li>
            <li><b>Alt+F7 Find Usages</b> works on keys in both PHP and JSON config files.</li>
        </ul>

        <h3>Hover documentation</h3>
        <ul>
            <li>Hovering an experiment key shows a popup with branches, percentages, override branch, and start date.</li>
        </ul>

        <h3>Status bar widget</h3>
        <ul>
            <li>Displays the total number of loaded experiments and config file count in the status bar.</li>
            <li>Click the widget to see a per-file breakdown and open any config file in the editor.</li>
            <li>Includes a <b>Reload configs</b> action to force a re-index.</li>
        </ul>

        <h3>File templates</h3>
        <ul>
            <li><b>Right-click → New → Experiments Config</b> — creates a new PHP or JSON config file with example experiments.</li>
            <li>Templates are also available in <b>Settings → Editor → File and Code Templates → Other</b> for customisation.</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.php</depends>
    <depends>JavaScript</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- App-level service: parsed config cache + VFS watcher -->
        <applicationService
            serviceImplementation="com.brighterly.experiments.service.ExperimentsService"/>

        <!-- App-level persistent settings (config file path) -->
        <applicationService
            serviceImplementation="com.brighterly.experiments.settings.ExperimentsSettings"/>

        <applicationConfigurable
            parentId="tools"
            instance="com.brighterly.experiments.settings.ExperimentsSettingsConfigurable"
            id="com.brighterly.experiments.settings"
            displayName="AB Tests"/>

        <!-- Ctrl+click / Go To Declaration -->
        <psi.referenceContributor
            language="PHP"
            implementation="com.brighterly.experiments.reference.ExperimentKeyReferenceContributor"/>

        <!-- Find Usages: Alt+F7 on a key in the config file finds all call sites -->
        <lang.findUsagesProvider
            language="PHP"
            implementationClass="com.brighterly.experiments.findusages.ExperimentFindUsagesProvider"
            order="first"/>

        <!-- Cmd+click on a key in the config file shows all usages instead of "no declaration" -->
        <gotoDeclarationHandler
            implementation="com.brighterly.experiments.findusages.ExperimentConfigGotoUsagesHandler"/>

        <!-- Literal-text searcher: feeds usages to ReferencesSearch, bypassing word-index
             splitting on hyphens in keys like "exp-23_pad-change-wording" -->
        <referencesSearch
            implementation="com.brighterly.experiments.findusages.ExperimentReferencesSearcher"/>

        <!-- Strikethrough for closed experiments -->
        <annotator
            language="PHP"
            implementationClass="com.brighterly.experiments.annotator.ExperimentAnnotator"/>

        <!-- Hover documentation popup -->
        <lang.documentationProvider
            language="PHP"
            implementationClass="com.brighterly.experiments.documentation.ExperimentDocumentationProvider"
            order="first"/>

        <!-- Declarative inlay hints: [80/20] after each experiment key -->
        <codeInsight.declarativeInlayProvider
            language="PHP"
            implementationClass="com.brighterly.experiments.hints.ExperimentInlayHintsProvider"
            isEnabledByDefault="true"
            group="OTHER_GROUP"
            providerId="brighterly.experiments.distribution"
            nameKey="inlay.hints.experiments.distribution.name"
            bundle="messages.ExperimentsBundle"/>

        <!-- Inline ⚠ hint in config files when branch percentages don't sum to 100 -->
        <codeInsight.declarativeInlayProvider
            language="PHP"
            implementationClass="com.brighterly.experiments.hints.ExperimentConfigInlayHintsProvider"
            isEnabledByDefault="true"
            group="OTHER_GROUP"
            providerId="brighterly.experiments.config.validation"
            nameKey="inlay.hints.experiments.config.validation.name"
            bundle="messages.ExperimentsBundle"/>
        <codeInsight.declarativeInlayProvider
            language="JSON"
            implementationClass="com.brighterly.experiments.hints.ExperimentConfigInlayHintsProvider"
            isEnabledByDefault="true"
            group="OTHER_GROUP"
            providerId="brighterly.experiments.config.validation"
            nameKey="inlay.hints.experiments.config.validation.name"
            bundle="messages.ExperimentsBundle"/>

        <!-- JS/TS reference: Ctrl+click on experiment keys in JS/TS files -->
        <psi.referenceContributor
            language="JavaScript"
            implementation="com.brighterly.experiments.reference.ExperimentKeyReferenceContributorJs"/>
        <psi.referenceContributor
            language="TypeScript"
            implementation="com.brighterly.experiments.reference.ExperimentKeyReferenceContributorJs"/>

        <!-- Strikethrough for closed experiments in JS/TS -->
        <annotator
            language="JavaScript"
            implementationClass="com.brighterly.experiments.annotator.ExperimentAnnotator"/>
        <annotator
            language="TypeScript"
            implementationClass="com.brighterly.experiments.annotator.ExperimentAnnotator"/>

        <!-- Hover documentation in JS/TS -->
        <lang.documentationProvider
            language="JavaScript"
            implementationClass="com.brighterly.experiments.documentation.ExperimentDocumentationProvider"
            order="first"/>
        <lang.documentationProvider
            language="TypeScript"
            implementationClass="com.brighterly.experiments.documentation.ExperimentDocumentationProvider"
            order="first"/>

        <!-- Inlay hints in JS/TS files -->
        <codeInsight.declarativeInlayProvider
            language="JavaScript"
            implementationClass="com.brighterly.experiments.hints.ExperimentInlayHintsProviderJs"
            isEnabledByDefault="true"
            group="OTHER_GROUP"
            providerId="brighterly.experiments.distribution.js"
            nameKey="inlay.hints.experiments.distribution.name"
            bundle="messages.ExperimentsBundle"/>
        <codeInsight.declarativeInlayProvider
            language="TypeScript"
            implementationClass="com.brighterly.experiments.hints.ExperimentInlayHintsProviderTs"
            isEnabledByDefault="true"
            group="OTHER_GROUP"
            providerId="brighterly.experiments.distribution.ts"
            nameKey="inlay.hints.experiments.distribution.name"
            bundle="messages.ExperimentsBundle"/>

        <!-- Status bar widget: shows "Exp ✓ 15" or "Exp ⚠" -->
        <statusBarWidgetFactory
            implementation="com.brighterly.experiments.statusbar.ExperimentsStatusBarWidgetFactory"
            id="brighterly.experiments.status"
            order="after Position"/>

        <!-- Find Usages: Alt+F7 on a key in a JSON config file -->
        <lang.findUsagesProvider
            language="JSON"
            implementationClass="com.brighterly.experiments.findusages.ExperimentFindUsagesProviderJson"
            order="first"/>

        <!-- File templates: registers PHP/JSON stubs with FileTemplateManager so
             CreateFileFromTemplateAction can look them up by name, and so they
             appear in Settings → Editor → File and Code Templates → Other -->
        <fileTemplates implementation="com.brighterly.experiments.actions.ExperimentsFileTemplateFactory"/>

    </extensions>

    <actions>
        <!-- New → Experiments Config in project tree context menu -->
        <action
            id="brighterly.experiments.NewConfig"
            class="com.brighterly.experiments.actions.NewExperimentsConfigAction"
            text="Experiments Config"
            description="Create a new experiments config file (PHP or JSON)"
            icon="/icons/newExperimentsConfig.svg">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
    </actions>

</idea-plugin>
